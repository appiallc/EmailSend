generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ContactList {
  id        String                @id @default(cuid())
  name      String
  createdAt DateTime              @default(now())
  contacts  Contact[]
  campaigns CampaignContactList[]
}

model Contact {
  id            String      @id @default(cuid())
  contactListId String
  email         String
  firstName     String      @default("")
  lastName      String      @default("")
  company       String      @default("")
  title         String      @default("")
  phone         String      @default("")
  notes         String      @default("")
  createdAt     DateTime    @default(now())
  contactList   ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)
  emailLogs     EmailLog[]

  @@unique([contactListId, email])
  @@index([contactListId])
}

model Campaign {
  id               String                @id @default(cuid())
  name             String
  subject          String
  bodyHtml         String
  followUpSubject  String                @default("")
  followUpBodyHtml String                @default("")
  followUpDays     Int                   @default(7)
  extraFollowUps   Json                  @default("[]")
  status           String                @default("draft") // draft | sending | sent | paused
  createdAt        DateTime              @default(now())
  sentAt           DateTime?
  emailLogs        EmailLog[]
  contactLists     CampaignContactList[]
}

model CampaignContactList {
  campaignId    String
  contactListId String
  campaign      Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactList   ContactList @relation(fields: [contactListId], references: [id], onDelete: Cascade)

  @@id([campaignId, contactListId])
}

model EmailLog {
  id          String    @id @default(cuid())
  campaignId  String
  contactId   String
  type        String    // initial | followup
  followUpStep Int      @default(0) // 0 = initial; 1+ = follow-up sequence
  status       String    @default("pending") // pending | sent | failed | opened | clicked | replied | bounced
  trackingId   String    @unique @default(cuid())
  messageId    String?
  error        String?
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  repliedAt    DateTime?
  bouncedAt    DateTime?
  bounceReason String?
  bounceType   String?   // HARD_BOUNCE | SOFT_BOUNCE
  followUpDue  DateTime?
  campaign    Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([contactId])
  @@index([followUpDue])
}

model Settings {
  id          String  @id @default("default")
  companyName String  @default("Your Company")
  smtpHost    String  @default("")
  smtpPort    Int     @default(587)
  smtpSecure  Boolean @default(false)
  smtpUser    String  @default("")
  smtpPass    String  @default("")
  smtpFrom    String  @default("")
  imapHost    String  @default("")
  imapPort    Int     @default(993)
  imapUser    String  @default("")
  imapPass    String  @default("")
  baseUrl     String  @default("http://localhost:3000")
}
